<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MospolitechProject.Views.ImportPage"
             BackgroundColor="#121212"
             Title="Импорт EPUB">

    <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="30" Spacing="25">

        <!-- Иконка как в твоем Android-приложении -->
        <Frame BackgroundColor="#1E1E1E" CornerRadius="50" WidthRequest="120" HeightRequest="120" Padding="0" HasShadow="False" HorizontalOptions="Center">
            <Label Text="📁" FontSize="60" HorizontalOptions="Center" VerticalOptions="Center" />
        </Frame>

        <Label Text="Добавьте книгу в формате EPUB" 
               TextColor="White" FontSize="22" FontAttributes="Bold" 
               HorizontalTextAlignment="Center" />

        <Label Text="Поддерживаются файлы с расширением .epub. Выберите файл для импорта в вашу библиотеку" 
               TextColor="#AAAAAA" FontSize="14" HorizontalTextAlignment="Center" />

        <!-- Кнопка выбора -->
        <Button Text="+ Выбрать EPUB файл" 
                BackgroundColor="#6200EE" TextColor="White" 
                CornerRadius="25" HeightRequest="50" WidthRequest="260"
                FontAttributes="Bold"
                Clicked="OnSelectFileClicked" />

        <!-- Индикатор процесса -->
        <StackLayout x:Name="LoadingLayout" IsVisible="False">
            <ActivityIndicator IsRunning="True" Color="#03DAC5" />
            <Label x:Name="StatusLabel" Text="Импортируем..." TextColor="#03DAC5" HorizontalOptions="Center" Margin="0,10,0,0"/>
        </StackLayout>

    </StackLayout>
</ContentPage>
