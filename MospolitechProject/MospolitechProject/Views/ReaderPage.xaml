<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MospolitechProject.Views.ReaderPage"
             BackgroundColor="#121212"
             Title="Чтение">

    <Grid RowDefinitions="*, Auto">
        <!-- 1. Область чтения -->
        <ScrollView x:Name="MainScroll" Grid.Row="0" Padding="20">
            <StackLayout>
                <Label x:Name="ContentLabel" 
                       TextColor="#E0E0E0" 
                       FontSize="18" 
                       LineHeight="1.4" 
                       FontFamily="Serif"
                       LineBreakMode="WordWrap"
                       Margin="0,0,0,20"
                       Text="Загрузка текста..."/>
                <BoxView HeightRequest="50" Color="Transparent"/>
            </StackLayout>
        </ScrollView>

        <ActivityIndicator x:Name="ReaderLoader" 
                           IsRunning="False" 
                           VerticalOptions="Center" 
                           HorizontalOptions="Center" 
                           Color="#03DAC5" />

        <!-- 2. Нижняя панель навигации -->
        <Frame Grid.Row="1" BackgroundColor="#1E1E1E" Padding="10" CornerRadius="0">
            <Grid ColumnDefinitions="*, *, *">
                <Button Grid.Column="0" Text="Назад" Clicked="OnPrevClicked" BackgroundColor="Transparent" TextColor="#03DAC5" FontSize="12"/>
                <Label Grid.Column="1" x:Name="ChapterLabel" Text="Глава 1" TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Button Grid.Column="2" Text="Вперед" Clicked="OnNextClicked" BackgroundColor="Transparent" TextColor="#03DAC5" FontSize="12"/>
            </Grid>
        </Frame>

        <!-- 3. КАСТОМНЫЙ ПОПАП -->
        <ContentView x:Name="CustomAlert" Grid.RowSpan="2" IsVisible="False" BackgroundColor="#AA000000">
            <Frame VerticalOptions="Center" HorizontalOptions="Center" 
                   BackgroundColor="#1E1E1E" CornerRadius="20" Padding="25" WidthRequest="300" HasShadow="True">
                <StackLayout Spacing="15">
                    <Label Text="📘" FontSize="50" HorizontalOptions="Center"/>
                    <Label Text="Книга прочитана!" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Вы дошли до последней страницы. Вернуться к книге?" 
                           TextColor="#AAAAAA" HorizontalTextAlignment="Center" FontSize="14"/>

                    <Button Text="ВЕРНУТЬСЯ К КНИГЕ" 
                            BackgroundColor="#6200EE" TextColor="White" 
                            CornerRadius="25" HeightRequest="50" Margin="0,10,0,0"
                            Clicked="OnAlertConfirmClicked"/>

                    <Button Text="ОСТАТЬСЯ ЗДЕСЬ" 
                            BackgroundColor="Transparent" TextColor="#03DAC5" 
                            FontSize="12"
                            Clicked="OnAlertCancelClicked"/>
                </StackLayout>
            </Frame>
        </ContentView>
    </Grid>
</ContentPage>
