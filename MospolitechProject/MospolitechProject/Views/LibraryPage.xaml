<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MospolitechProject.Views.LibraryPage"
             BackgroundColor="#121212"
             Title="Моя библиотека">

    <!-- Используем StackLayout для заголовка и статов, а Grid только для списка -->
    <StackLayout Spacing="0">

        <!-- Заголовок -->
        <StackLayout Padding="20,15,20,5">
            <Label Text="Моя библиотека" TextColor="White" FontSize="26" FontAttributes="Bold"/>
            <Label x:Name="BooksCountLabel" Text="0 книг в библиотеке" TextColor="Gray" FontSize="14"/>
        </StackLayout>

        <!-- Карточки статистики (теперь фиксированной высоты) -->
        <FlexLayout JustifyContent="SpaceEvenly" Padding="10,5" HeightRequest="100" AlignItems="Start">
            <Frame BackgroundColor="#1E1E1E" CornerRadius="12" HasShadow="False" WidthRequest="120" HeightRequest="80" Padding="10">
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label x:Name="ReadingCountLabel" Text="0" TextColor="#03DAC5" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Читаю" TextColor="Gray" FontSize="10" HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>

            <Frame BackgroundColor="#1E1E1E" CornerRadius="12" HasShadow="False" WidthRequest="120" HeightRequest="80" Padding="10">
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label x:Name="FinishedCountLabel" Text="0" TextColor="#BB86FC" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Прочитано" TextColor="Gray" FontSize="10" HorizontalOptions="Center"/>
                </StackLayout>
            </Frame>
        </FlexLayout>

        <!-- Список книг и FAB -->
        <Grid VerticalOptions="FillAndExpand">
            <CollectionView x:Name="BooksCollection" Margin="15,5" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView BackgroundColor="Transparent">
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">
                                    <SwipeItemView Invoked="OnDeleteInvoked" CommandParameter="{Binding .}">
                                        <!-- Красная кнопка удаления -->
                                        <Frame BackgroundColor="Red" 
                           CornerRadius="15" 
                           Margin="5,8" 
                           Padding="15,0"
                           HasShadow="False">
                                            <Label Text="Удалить" 
                               TextColor="White" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               FontAttributes="Bold"/>
                                        </Frame>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <!-- Основная карточка книги -->
                            <Frame BackgroundColor="#1E1E1E" 
               CornerRadius="15" 
               Margin="8,4" 
               Padding="12" 
               HasShadow="False"
               IsClippedToBounds="True">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBookTapped" CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>

                                <Grid ColumnDefinitions="80, *, Auto" RowDefinitions="Auto, Auto, Auto">
                                    <!-- Обложка -->
                                    <Frame Grid.RowSpan="3" 
                       BackgroundColor="#2C2C2C" 
                       Padding="0" 
                       CornerRadius="8" 
                       IsClippedToBounds="True" 
                       WidthRequest="70" 
                       HeightRequest="100">
                                        <Image Source="{Binding CoverUrl}" Aspect="AspectFill" />
                                    </Frame>

                                    <!-- Инфо -->
                                    <StackLayout Grid.Column="1" Margin="12,0">
                                        <Label Text="{Binding Title}" TextColor="White" FontAttributes="Bold" FontSize="16" MaxLines="1"/>
                                        <Label Text="{Binding Author}" TextColor="Gray" FontSize="13" MaxLines="1"/>
                                    </StackLayout>

                                    <!-- Прогресс -->
                                    <StackLayout Grid.Row="2" Grid.Column="1" Margin="12,0,0,0" VerticalOptions="End">
                                        <ProgressBar Progress="{Binding ProgressPercent}" ProgressColor="#6200EE"/>
                                        <Label Text="{Binding ProgressText}" TextColor="Gray" FontSize="10" HorizontalOptions="End"/>
                                    </StackLayout>
                                </Grid>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>

                </CollectionView.ItemTemplate>
            </CollectionView>


            <!-- Кнопка + (FAB) -->
            <Button Text="+" 
                    BackgroundColor="#6200EE" 
                    TextColor="White" 
                    FontSize="24"
                    CornerRadius="28" 
                    WidthRequest="56" 
                    HeightRequest="56" 
                    HorizontalOptions="End" 
                    VerticalOptions="End" 
                    Margin="20" 
                    Clicked="OnImportClicked"/>
        </Grid>
    </StackLayout>
</ContentPage>
